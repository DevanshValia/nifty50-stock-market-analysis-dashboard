WITH returns AS (SELECT date, symbol, ((close - LAG(close) OVER (PARTITION BY symbol ORDER BY date))/
(LAG(close) OVER (PARTITION BY symbol ORDER BY date ))) * 100 AS daily_return
FROM nifty50_data)
SELECT symbol, ROUND(STDDEV(daily_return),2) AS volatility 
FROM returns
GROUP BY symbol
ORDER BY volatility DESC;
