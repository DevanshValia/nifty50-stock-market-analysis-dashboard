-- VIEW FOR DAILY RETURNS:
CREATE VIEW stock_daily_returns AS

SELECT
    date,
    symbol,
    close,
    ROUND(
        (
            (close - LAG(close) OVER (PARTITION BY symbol ORDER BY date))
            /
            LAG(close) OVER (PARTITION BY symbol ORDER BY date)
        ) * 100,
        2
    ) AS daily_returns
FROM nifty50_data;


-- VIEW FOR VOLATILITY:
CREATE OR REPLACE VIEW stock_volatility AS

WITH returns AS (
    SELECT
        date,
        symbol,
        (
            (close - LAG(close) OVER (PARTITION BY symbol ORDER BY date))
            / LAG(close) OVER (PARTITION BY symbol ORDER BY date)
        ) * 100 AS daily_return
    FROM nifty50_data
)

SELECT
    symbol,
    ROUND(STDDEV(daily_return), 2) AS volatility
FROM returns
GROUP BY symbol
ORDER BY volatility DESC;



-- VIEW FOR CCAGR:
CREATE VIEW stock_cagr AS
WITH first_price AS(
SELECT symbol, date AS start_date, close AS start_price, 
ROW_NUMBER() OVER(
PARTITION BY symbol
ORDER BY date ASC
) AS rn
FROM nifty50_data
),
last_price AS(
SELECT symbol, date AS end_date, close AS end_price, 
ROW_NUMBER() OVER(
PARTITION BY symbol
ORDER BY date DESC
) AS rn 
FROM nifty50_data
),
price_data AS (
SELECT f.symbol,f.start_price,l.end_price,f.start_date,l.end_date,
(l.end_date - f.start_date) / 365.25 AS years
FROM first_price f
JOIN last_price l
ON f.symbol = l.symbol
WHERE f.rn = 1 
AND l.rn = 1
)
SELECT symbol, start_price, end_price, years,
ROUND(
(
POWER(end_price/start_price, 1.0/years) - 1
) * 100,2
) AS cagr_percent
FROM price_data
ORDER BY cagr_percent DESC;


-- VIEW FOR STOCK OVERVIEW:
CREATE VIEW stock_overview AS
SELECT symbol,
ROUND(AVG(close),2) AS avg_close,
ROUND(AVG(volume),0) AS avg_volume,
ROUND(AVG(turnover),2) AS avg_turnover
FROM nifty50_data 
GROUP BY symbol;
